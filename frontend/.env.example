# ============================================================
# Midnight ZK-Audit Bridge — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to git — only .env.example

# ── Midnight Network ──────────────────────────────────────────
VITE_MIDNIGHT_NETWORK_ID=preprod
VITE_MIDNIGHT_INDEXER_URL=https://indexer.testnet-02.midnight.network/api/v1/graphql
VITE_MIDNIGHT_INDEXER_WS_URL=wss://indexer.testnet-02.midnight.network/api/v1/graphql/ws

# ── Deployed Contract ─────────────────────────────────────────
# Set this after running: node scripts/deploy.mjs
# Leave empty to use simulation mode
VITE_CONTRACT_ADDRESS=

# ── ZK Proof Server (local) ───────────────────────────────────
# Run the proof server locally: https://docs.midnight.network/develop/midnight-js/proof-server
MIDNIGHT_PROOF_SERVER_URL=http://localhost:6300

# ── Demo Fallback ─────────────────────────────────────────────
# Set to "true" to allow a mock wallet when Lace extension is not found
# Useful for judges reviewing the Vercel deployment without the extension
VITE_ALLOW_MOCK_WALLET=true
